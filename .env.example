# ── 必填 ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=你的bot_token
TELEGRAM_CHAT_ID=你的chat_id

# ── Daemon 基础参数 ──────────────────────────────────
DEFAULT_INTERVAL=120
ACTIVE_START=10
ACTIVE_END=1
FORGE_THRESHOLD=180000
RETAIN_TOKENS=15000
SONNET_FORGE_THRESHOLD=180000
SONNET_RETAIN_TOKENS=15000
GROUP_MAX_ROUNDS=10
EMOTION_SCAN_INTERVAL=15

# ── WebSocket / Web ─────────────────────────────────
WS_PORT=8765
WS_SECRET=你的ws密钥
WEB_PORT=3000

# ── DeepSeek 数据助手 ───────────────────────────────
DEEPSEEK_API_KEY=你的deepseek_api_key
DEEPSEEK_MODEL=deepseek-v4-pro

# ── Supabase（DeepSeek 查数据用） ───────────────────
SUPABASE_URL=https://你的项目id.supabase.co
SUPABASE_KEY=你的supabase_anon_key

# ── 天气（和风天气） ────────────────────────────────
QWEATHER_API_KEY=你的和风天气key
QWEATHER_HOST=你的和风天气host
QWEATHER_CITY=101190205

# ── 网络代理（可选） ────────────────────────────────
HTTP_PROXY=http://127.0.0.1:端口
